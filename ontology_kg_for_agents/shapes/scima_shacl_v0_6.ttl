# =====================================================================
# SCIMA SHACL shapes, generated from SCIMA-OWL v0.6 (Article 5)
#
# These shapes are the standards-track form of the compliance gate in
# scima/kg_extraction.py. Each shape is derived mechanically from the
# ontology: an object property's rdfs:range becomes an sh:class constraint,
# a datatype property's rdfs:range becomes an sh:datatype constraint, and
# the domain/disjointness axioms drive node-level targets.
#
# The runnable pipeline performs the equivalent checks natively (pyshacl is
# an optional dependency), the same way scima/knowledge_graph.py computes a
# haversine distance in place of a GeoSPARQL geof:distance. Validate with:
#     pip install pyshacl
#     pyshacl -s shapes/scima_shacl_v0_6.ttl build/scima_kg_I204.ttl
# Conformance against the admitted A-Box is True by construction: the gate
# never admits a triple that would make a shape fail.
# =====================================================================

@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix scima: <http://scima.city/ontology#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .

# --- Incident commander: must command at least one incident; the units and
#     zones it touches must be the right kinds. ---
scima:IncidentCommanderShape a sh:NodeShape ;
    sh:targetClass scima:IncidentCommander ;
    sh:property [
        sh:path     scima:commands ;
        sh:class    scima:Incident ;        # range enforced (HazMatSpill is an Incident)
        sh:minCount 1 ;                      # a commander commands at least one incident
    ] ;
    sh:property [
        sh:path  scima:designates ;
        sh:class scima:EvacuationZone ;
    ] .

# --- Responder unit: what it is dispatched to and which protocol it follows. ---
scima:ResponderUnitShape a sh:NodeShape ;
    sh:targetClass scima:ResponderUnit ;     # HazmatTeam / FireDepartment / EMS
    sh:property [
        sh:path  scima:dispatchedTo ;
        sh:class scima:Incident ;
    ] ;
    sh:property [
        sh:path  scima:followsProtocol ;
        sh:class scima:HazardousMaterialProtocol ;
    ] .

# --- Incident: status is a string; what it affects is infrastructure. ---
scima:IncidentShape a sh:NodeShape ;
    sh:targetClass scima:Incident ;
    sh:property [
        sh:path     scima:hasStatus ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path  scima:affects ;
        sh:class scima:InfrastructureEntity ;
    ] .

# --- Sensor reading: observed value is an integer, recorded by a sensor. ---
scima:SensorReadingShape a sh:NodeShape ;
    sh:targetClass scima:SensorReading ;
    sh:property [
        sh:path     scima:observedValue ;
        sh:datatype xsd:integer ;            # drives the "47" string -> int repair
    ] ;
    sh:property [
        sh:path  scima:recordedBy ;
        sh:class scima:SensorDevice ;
    ] .

# --- Sensor device: monitors infrastructure. ---
scima:SensorDeviceShape a sh:NodeShape ;
    sh:targetClass scima:SensorDevice ;
    sh:property [
        sh:path  scima:monitors ;
        sh:class scima:InfrastructureEntity ;
    ] .

# --- The three responder units are mutually disjoint; SHACL closes the world
#     enough to forbid a node carrying two of them. The reasoner makes the same
#     check under the open-world assumption. ---
scima:HazmatTeamShape a sh:NodeShape ;
    sh:targetClass scima:HazmatTeam ;
    sh:not [ sh:class scima:FireDepartment ] ;
    sh:not [ sh:class scima:EmergencyMedicalService ] .
