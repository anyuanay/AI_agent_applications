# =====================================================================
# SCIMA-OWL v0.5  (Article 3: Context Graphs and Dynamic Working Memory)
# SmartCity Infrastructure Management Agent.
#
# v0.5 adds the vocabulary an agent needs to hold a *context graph*: the
# agents themselves, the goals they pursue, the working-memory projection,
# and the vehicles a dispatcher reasons over. Growth Tracker target
# (cumulative):
#   18 classes, 30 properties (15 object + 15 datatype), 12 axioms.
# Delta over v0.2: 6 new classes, 10 new properties, 4 new axioms.
#
# This file is the canonical schema; the article shows a curated excerpt.
# Context graphs are NOT serialized here; they are projected at runtime
# from a populated KG by scima/context_graph.py.
# =====================================================================

@prefix scima: <http://scima.city/ontology#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .

# --- Ontology header ---
<http://scima.city/ontology> a owl:Ontology ;
    owl:versionInfo "0.5" ;
    owl:priorVersion <http://scima.city/ontology/v0.2> ;
    rdfs:label "SCIMA-OWL" ;
    rdfs:comment "Agent, goal, and context-graph vocabulary for dynamic working memory." .

# =====================================================================
# CLASSES (18 = 12 from v0.2 + 6 new)
# =====================================================================

# --- Top level concept (v0.1) ---
scima:InfrastructureEntity a owl:Class ;
    rdfs:label "Infrastructure Entity" ;
    rdfs:comment "Any managed piece of physical city infrastructure." .

# --- Infrastructure subclasses (v0.1) ---
scima:RoadSegment a owl:Class ;
    rdfs:subClassOf scima:InfrastructureEntity ;
    rdfs:label "Road Segment" .

scima:TrafficLight a owl:Class ;
    rdfs:subClassOf scima:InfrastructureEntity ;
    rdfs:label "Traffic Light" .

scima:PowerNode a owl:Class ;
    rdfs:subClassOf scima:InfrastructureEntity ;
    rdfs:label "Power Node" .

scima:WaterMain a owl:Class ;
    rdfs:subClassOf scima:InfrastructureEntity ;
    rdfs:label "Water Main" .

# --- Sensing (v0.1) ---
scima:SensorDevice a owl:Class ;
    rdfs:label "Sensor Device" ;
    rdfs:comment "A device that observes the state of infrastructure." .

scima:SensorReading a owl:Class ;
    rdfs:label "Sensor Reading" ;
    rdfs:comment "A single timestamped observation from a sensor device." .

# --- Disruptive events (v0.1) ---
scima:Incident a owl:Class ;
    rdfs:label "Incident" ;
    rdfs:comment "A disruptive event affecting one or more infrastructure entities." .

# --- Concrete sensor kinds + transit (v0.2) ---
scima:TrafficCamera a owl:Class ;
    rdfs:subClassOf scima:SensorDevice ;
    rdfs:label "Traffic Camera" .

scima:FlowSensor a owl:Class ;
    rdfs:subClassOf scima:SensorDevice ;
    rdfs:label "Flow Sensor" .

scima:PowerMeter a owl:Class ;
    rdfs:subClassOf scima:SensorDevice ;
    rdfs:label "Power Meter" .

scima:TransitStop a owl:Class ;
    rdfs:subClassOf scima:InfrastructureEntity ;
    rdfs:label "Transit Stop" .

# --- (13) NEW in v0.5: the agents that act on the city ---
scima:Agent a owl:Class ;
    rdfs:label "Agent" ;
    rdfs:comment "An autonomous decision maker that perceives, plans, and acts." .

# --- (14-15) NEW in v0.5: agent roles ---
scima:ZoneAgent a owl:Class ;
    rdfs:subClassOf scima:Agent ;
    rdfs:label "Zone Agent" ;
    rdfs:comment "An agent responsible for one district of the city." .

scima:DispatchAgent a owl:Class ;
    rdfs:subClassOf scima:Agent ;
    rdfs:label "Dispatch Agent" ;
    rdfs:comment "An agent that assigns vehicles and crews to incidents." .

# --- (16) NEW in v0.5: what an agent is trying to achieve ---
scima:GoalState a owl:Class ;
    rdfs:label "Goal State" ;
    rdfs:comment "A target world state an agent is committed to bringing about." .

# --- (17) NEW in v0.5: the agent's dynamic working memory ---
scima:ContextGraph a owl:Class ;
    rdfs:label "Context Graph" ;
    rdfs:comment "A task-scoped projection of the KG that an agent reasons over." .

# --- (18) NEW in v0.5: mobile resources a dispatcher reasons over ---
scima:Vehicle a owl:Class ;
    rdfs:label "Vehicle" ;
    rdfs:comment "A mobile resource such as an ambulance, crew truck, or bus." .

# =====================================================================
# PROPERTIES (30 = 20 from v0.2 + 10 new)
# =====================================================================

# --- Object properties from v0.2 (8) ---
scima:locatedOn a owl:ObjectProperty ;
    rdfs:domain scima:TrafficLight ; rdfs:range scima:RoadSegment ; rdfs:label "located on" .
scima:monitors a owl:ObjectProperty ;
    rdfs:domain scima:SensorDevice ; rdfs:range scima:InfrastructureEntity ; rdfs:label "monitors" .
scima:hasReading a owl:ObjectProperty ;
    rdfs:domain scima:SensorDevice ; rdfs:range scima:SensorReading ; rdfs:label "has reading" .
scima:affects a owl:ObjectProperty ;
    rdfs:domain scima:Incident ; rdfs:range scima:InfrastructureEntity ; rdfs:label "affects" .
scima:connectedTo a owl:ObjectProperty ;
    rdfs:domain scima:RoadSegment ; rdfs:range scima:RoadSegment ; rdfs:label "connected to" .
scima:poweredBy a owl:ObjectProperty ;
    rdfs:domain scima:InfrastructureEntity ; rdfs:range scima:PowerNode ; rdfs:label "powered by" .
scima:recordedBy a owl:ObjectProperty ;
    rdfs:domain scima:SensorReading ; rdfs:range scima:SensorDevice ; rdfs:label "recorded by" .
scima:servesStop a owl:ObjectProperty ;
    rdfs:domain scima:RoadSegment ; rdfs:range scima:TransitStop ; rdfs:label "serves stop" .

# --- NEW object properties in v0.5 (7) ---
scima:pursuesGoal a owl:ObjectProperty ;
    rdfs:domain scima:Agent ; rdfs:range scima:GoalState ;
    rdfs:label "pursues goal" ;
    rdfs:comment "Links an agent to a goal it is committed to." .

scima:targets a owl:ObjectProperty ;
    rdfs:domain scima:GoalState ; rdfs:range scima:InfrastructureEntity ;
    rdfs:label "targets" ;
    rdfs:comment "The entity a goal is about, e.g. the incident to resolve." .

scima:respondsTo a owl:ObjectProperty ;
    rdfs:domain scima:Agent ; rdfs:range scima:Incident ;
    rdfs:label "responds to" ;
    rdfs:comment "Links an agent to an incident it is handling." .

scima:managedBy a owl:ObjectProperty ;
    rdfs:domain scima:InfrastructureEntity ; rdfs:range scima:ZoneAgent ;
    rdfs:label "managed by" ;
    rdfs:comment "The zone agent responsible for an infrastructure entity." .

scima:hasFocalEntity a owl:ObjectProperty ;
    rdfs:domain scima:ContextGraph ;
    rdfs:label "has focal entity" ;
    rdfs:comment "The entity a context graph is centred on." .

scima:includesEntity a owl:ObjectProperty ;
    rdfs:domain scima:ContextGraph ;
    rdfs:label "includes entity" ;
    rdfs:comment "An entity currently held in a context graph." .

scima:assignedTo a owl:ObjectProperty ;
    rdfs:domain scima:Vehicle ; rdfs:range scima:Incident ;
    rdfs:label "assigned to" ;
    rdfs:comment "Set when a dispatcher commits a vehicle to an incident." .

# --- Datatype properties from v0.2 (12) ---
scima:hasSpeedLimit a owl:DatatypeProperty ;
    rdfs:domain scima:RoadSegment ; rdfs:range xsd:integer ; rdfs:label "has speed limit" .
scima:hasIdentifier a owl:DatatypeProperty ;
    rdfs:domain scima:InfrastructureEntity ; rdfs:range xsd:string ; rdfs:label "has identifier" .
scima:timestamp a owl:DatatypeProperty ;
    rdfs:domain scima:SensorReading ; rdfs:range xsd:dateTime ; rdfs:label "timestamp" .
scima:confidenceScore a owl:DatatypeProperty ;
    rdfs:domain scima:SensorReading ; rdfs:range xsd:decimal ; rdfs:label "confidence score" .
scima:hasStatus a owl:DatatypeProperty ;
    rdfs:domain scima:Incident ; rdfs:range xsd:string ; rdfs:label "has status" .
scima:hasVoltage a owl:DatatypeProperty ;
    rdfs:domain scima:PowerNode ; rdfs:range xsd:decimal ; rdfs:label "has voltage" .
scima:observedValue a owl:DatatypeProperty ;
    rdfs:domain scima:SensorReading ; rdfs:range xsd:integer ; rdfs:label "observed value" .
scima:hasTimestamp a owl:DatatypeProperty ;
    rdfs:domain scima:SensorReading ; rdfs:range xsd:dateTime ; rdfs:label "has timestamp" .
scima:hasConfidenceScore a owl:DatatypeProperty ;
    rdfs:domain scima:SensorReading ; rdfs:range xsd:decimal ; rdfs:label "has confidence score" .
scima:hasFlowRate a owl:DatatypeProperty ;
    rdfs:domain scima:SensorReading ; rdfs:range xsd:decimal ; rdfs:label "has flow rate" .
scima:hasLatitude a owl:DatatypeProperty ;
    rdfs:range xsd:decimal ; rdfs:label "has latitude" .
scima:hasLongitude a owl:DatatypeProperty ;
    rdfs:range xsd:decimal ; rdfs:label "has longitude" .

# --- NEW datatype properties in v0.5 (3): relevance bookkeeping + availability ---
scima:relevanceScore a owl:DatatypeProperty ;
    rdfs:range xsd:decimal ;
    rdfs:label "relevance score" ;
    rdfs:comment "Combined relevance of an entity to a context graph, in [0,1]." .

scima:hopDistance a owl:DatatypeProperty ;
    rdfs:range xsd:integer ;
    rdfs:label "hop distance" ;
    rdfs:comment "Number of edges from the context graph's focal entity." .

scima:hasAvailability a owl:DatatypeProperty ;
    rdfs:domain scima:Vehicle ; rdfs:range xsd:string ;
    rdfs:label "has availability" ;
    rdfs:comment "A vehicle's dispatch state, e.g. available or busy." .

# =====================================================================
# AXIOMS (12 = 8 from v0.2 + 4 new)  beyond basic subclass/domain/range
# Counted by scima/ontology.py: owl:disjointWith + property characteristics.
# =====================================================================

# --- Disjointness from v0.1/v0.2 (5) ---
scima:RoadSegment owl:disjointWith scima:TrafficLight .
scima:RoadSegment owl:disjointWith scima:PowerNode .
scima:PowerNode   owl:disjointWith scima:WaterMain .
scima:SensorDevice  owl:disjointWith scima:InfrastructureEntity .
scima:SensorReading owl:disjointWith scima:SensorDevice .

# --- Property characteristics from v0.1/v0.2 (3) ---
scima:connectedTo a owl:SymmetricProperty .
scima:hasIdentifier a owl:FunctionalProperty .
scima:recordedBy a owl:FunctionalProperty .

# --- NEW in v0.5 (4): agents are a distinct kind, and scoping is single-focus ---
scima:Agent owl:disjointWith scima:InfrastructureEntity .
scima:Agent owl:disjointWith scima:SensorDevice .
scima:ZoneAgent owl:disjointWith scima:DispatchAgent .
# A context graph is centred on exactly one focal entity.
scima:hasFocalEntity a owl:FunctionalProperty .
